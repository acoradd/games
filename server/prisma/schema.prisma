generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["games"]
}

model GameMode {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  description  String?
  minPlayers   Int      @default(2) @map("min_players")
  maxPlayers   Int      @default(4) @map("max_players")
  thumbnailUrl String?  @map("thumbnail_url")
  isActive     Boolean  @default(true) @map("is_active")
  options      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("game_modes")
  @@schema("games")
}

model Player {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  displayName  String        @unique @map("display_name")
  passwordHash String        @map("password_hash")
  email         String?
  colorblindMode Boolean      @default(false) @map("colorblind_mode")
  createdAt    DateTime      @default(now()) @map("created_at")
  lastSeenAt   DateTime      @default(now()) @map("last_seen_at")
  sessions     GameSession[]

  @@map("players")
  @@schema("games")
}

model GameSession {
  id           Int      @id @default(autoincrement())
  gameId       String   @map("game_id")
  playerId     Int      @map("player_id")
  gameModeSlug String   @map("game_mode_slug")
  result       String   // "win" | "loss"
  score        Int      @default(0)
  playedAt     DateTime @default(now()) @map("played_at")
  player       Player   @relation(fields: [playerId], references: [id])

  @@index([gameId])
  @@map("game_sessions")
  @@schema("games")
}

model Word {
  id          Int     @id @default(autoincrement())
  text        String  @unique
  length      Int
  frequency   Float
  isGuessable Boolean

  @@index([length, isGuessable, frequency])
  @@map("words")
  @@schema("games")
}
